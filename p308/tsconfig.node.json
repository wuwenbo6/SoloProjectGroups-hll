{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "./out/main",
    "types": ["node"]
  },
  "include": ["electron/**/*.ts"]
}
