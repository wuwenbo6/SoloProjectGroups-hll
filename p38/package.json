{
  "name": "electronic-load-controller",
  "version": "1.0.0",
  "description": "Electron application for controlling programmable electronic loads via WebUSB",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": [
    "electron",
    "webusb",
    "electronic-load",
    "bk8540"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "winston": "^3.11.0"
  },
  "build": {
    "appId": "com.electronicload.controller",
    "productName": "Electronic Load Controller",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "deb"
    }
  }
}
