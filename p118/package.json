{
  "name": "dashcam-collision-detector",
  "version": "1.0.0",
  "description": "行车记录仪视频分析系统 - 前车检测、距离估算与碰撞预警",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "install:opencv": "npm install opencv4nodejs --build-from-source",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": ["electron", "opencv", "dashcam", "collision-detection"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1"
  },
  "optionalDependencies": {
    "opencv4nodejs": "^5.6.0"
  },
  "build": {
    "appId": "com.dashcam.detector",
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
