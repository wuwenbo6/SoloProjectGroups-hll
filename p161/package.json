{
  "name": "hkp-server",
  "version": "1.0.0",
  "description": "HTTP Keyserver Protocol (HKP) server with PostgreSQL backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "init-db": "node src/scripts/init-db.js",
    "migrate:text-fields": "node src/scripts/migrate-text-fields.js",
    "migrate:signatures": "node src/scripts/migrate-signatures.js",
    "migrate:all": "node src/scripts/migrate-text-fields.js && node src/scripts/migrate-signatures.js"
  },
  "keywords": [
    "hkp",
    "openpgp",
    "pgp",
    "keyserver"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "openpgp": "^5.11.0",
    "dotenv": "^16.3.1",
    "multer": "^1.4.5-lts.1",
    "body-parser": "^1.20.2",
    "ejs": "^3.1.9"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
