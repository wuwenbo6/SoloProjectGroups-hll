{
  "name": "bacnet-mstp-monitor",
  "version": "1.0.0",
  "description": "BACnet MS/TP Bus Monitor - Capture frames, parse APDU, display device object tree",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev": "concurrently \"npm run build:main -- -w\" \"webpack serve --config webpack.renderer.config.js\" \"wait-on http://localhost:9000 && electron .\""
  },
  "dependencies": {
    "css-loader": "^7.1.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "serialport": "^12.0.0",
    "style-loader": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "html-webpack-plugin": "^5.5.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  }
}
