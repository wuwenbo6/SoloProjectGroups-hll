{
  "name": "can-analyzer",
  "version": "1.0.0",
  "description": "CAN报文分析工具 - 自动识别信号边界并生成DBC文件",
  "main": "src/electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "author": "CAN Analyzer Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "python-shell": "^5.0.0"
  },
  "build": {
    "appId": "com.canalyzer.app",
    "productName": "CAN Analyzer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "python/**/*",
      "node_modules/**/*"
    ]
  }
}
