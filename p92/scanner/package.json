{
  "name": "document-scanner",
  "version": "1.0.0",
  "description": "文档扫描应用 - 边缘检测、透视变换、导出PDF/PNG",
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },
  "keywords": ["document", "scanner", "opencv", "electron"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "build": {
    "appId": "com.docscanner.app",
    "productName": "DocumentScanner",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "frontend/**/*",
      "python/**/*",
      "node_modules/**/*"
    ]
  }
}
