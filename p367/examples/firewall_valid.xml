<firewall>
    <settings>
        <enabled>true</enabled>
        <default-policy>drop</default-policy>
    </settings>
    <rule>
        <id>1</id>
        <name>Allow HTTP</name>
        <action>accept</action>
        <destination-port>80</destination-port>
        <protocol>tcp</protocol>
        <priority>5</priority>
        <log>false</log>
        <enabled>true</enabled>
    </rule>
    <rule>
        <id>2</id>
        <name>Allow SSH</name>
        <action>accept</action>
        <destination-port>22</destination-port>
        <protocol>tcp</protocol>
        <priority>3</priority>
        <log>true</log>
        <enabled>true</enabled>
    </rule>
    <rule>
        <id>3</id>
        <name>Dropped rule</name>
        <action>drop</action>
        <source-ip>192.168.1.100</source-ip>
        <log>false</log>
        <enabled>true</enabled>
    </rule>
    <nat>
        <external-ip>203.0.113.1</external-ip>
        <internal-ip>192.168.1.1</internal-ip>
        <enabled>true</enabled>
    </nat>
</firewall>
