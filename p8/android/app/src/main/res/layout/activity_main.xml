<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="室内定位系统"
                android:textColor="#00d4ff"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#16213e"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="服务器设置"
                        android:textColor="#7b8794"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:hintTextColor="#00d4ff"
                        app:boxStrokeColor="#00d4ff">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/serverUrl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="服务器地址"
                            android:text="http://192.168.1.100:3000"
                            android:textColor="#ffffff"
                            android:inputType="textUri" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btnConnect"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="连接服务器"
                        android:backgroundTint="#00d4ff"
                        android:textColor="#1a1a2e"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#16213e"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="设备状态"
                        android:textColor="#7b8794"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RTT支持: "
                            android:textColor="#7b8794" />

                        <TextView
                            android:id="@+id/rttStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="检测中..."
                            android:textColor="#ffcc00" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wi-Fi: "
                            android:textColor="#7b8794" />

                        <TextView
                            android:id="@+id/wifiStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="检测中..."
                            android:textColor="#ffcc00" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="定位: "
                            android:textColor="#7b8794" />

                        <TextView
                            android:id="@+id/locationStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="未启动"
                            android:textColor="#ff6b6b" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#16213e"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="当前位置"
                        android:textColor="#7b8794"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/positionDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="等待定位..."
                        android:textColor="#ffffff"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="#0f3460"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/accuracyDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="精度: --"
                        android:textColor="#4ecdc4"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#16213e"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PDR 航位推算"
                        android:textColor="#7b8794"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="步数: "
                            android:textColor="#7b8794" />

                        <TextView
                            android:id="@+id/stepCountDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#00d4ff"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="方向: "
                            android:textColor="#7b8794" />

                        <TextView
                            android:id="@+id/directionDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--°"
                            android:textColor="#ffcc00" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/pdrPositionDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PDR: 未初始化"
                        android:textColor="#7b8794"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="#0f3460" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#16213e"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="检测到的AP"
                        android:textColor="#7b8794"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/apCount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="已发现: 0 个AP"
                        android:textColor="#00d4ff"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/apList"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:text=""
                        android:textColor="#ffffff"
                        android:textSize="12sp"
                        android:background="#0f3460"
                        android:padding="8dp"
                        android:scrollbars="vertical"
                        android:typeface="monospace" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="开始定位"
                android:backgroundTint="#00ff88"
                android:textColor="#1a1a2e"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="停止定位"
                android:backgroundTint="#ff6b6b"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:enabled="false" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
